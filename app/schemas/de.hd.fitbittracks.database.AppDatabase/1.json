    "views": [
      {
        "viewName": "MilestoneWithTotalDistance",
        "createSql": "CREATE VIEW `${VIEW_NAME}` AS SELECT\n    m.*,\n    SUM(m.distanceOffsetToPrevious) OVER (\n      PARTITION BY m.trackId\n      ORDER BY m.id\n      ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW\n    ) AS totalDistance\n  FROM milestone m"
      }
    ],
