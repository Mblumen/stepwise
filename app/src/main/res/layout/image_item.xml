<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/milestone_image_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/image_margin"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <FrameLayout
            android:layout_width="@dimen/image_size_large"
            android:layout_height="@dimen/image_size_large">
        <ImageView
            android:id="@+id/milestone_image"
            android:layout_width="@dimen/image_size_large"
            android:layout_height="@dimen/image_size_large"
            android:scaleType="centerCrop"
            android:contentDescription="@string/milestone_image"
            android:transitionName="carouselImage"
            android:background="@drawable/rounded_image_background"
            tools:src="@drawable/berlin" />
            <ImageButton
                android:id="@+id/expand_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:background="@drawable/expand_button_bg"
                android:src="@drawable/expand"
                android:contentDescription="@string/expand_image"
                app:tint="@color/white"/>
        </FrameLayout>

        <TextView
            android:id="@+id/milestone_image_description"
            android:layout_width="@dimen/image_size_large"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/dark_gray"
            android:textSize="@dimen/font_size_small"
            android:textAlignment="center"
            android:fontFamily="sans-serif-medium"
            tools:text="Checkpoint Charlie, Berlin, blablablabla das ist länger"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>