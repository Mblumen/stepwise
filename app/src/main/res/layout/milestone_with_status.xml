<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/light_gray"
    android:layout_marginBottom="@dimen/list_item_spacing">
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dark_gray"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <LinearLayout
        android:id="@+id/milestone_unlocked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:padding="8dp">
        <FrameLayout
            android:layout_width="@dimen/image_size"
            android:layout_height="@dimen/image_size"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/milestone_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/milestone_image_content_description"
                tools:src="@drawable/berlin"/>

            <ImageView
                android:id="@+id/milestone_status_badge"
                android:layout_width="@dimen/icon_size_big"
                android:layout_height="@dimen/icon_size_big"
                android:layout_gravity="top|end"
                android:layout_margin="2dp"
                android:src="@drawable/check_circle"
                android:contentDescription="@string/milestone_completed"
                app:tint="@color/success_green"
                android:visibility="gone"
                tools:visibility="visible"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/milestone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="@dimen/card_description_padding"
            android:paddingEnd="@dimen/card_description_padding"
            tools:layout_width="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/milestone_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textSize="@dimen/font_size_normal"
                    android:textColor="@color/dark_gray"
                    android:layout_marginBottom="2dp"
                    tools:text="Title Spot" />

                <ImageButton
                    android:id="@+id/milestone_map_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/show_on_map"
                    android:src="@drawable/map"
                    app:tint="@color/dark_gray" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/milestone_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:drawableStartCompat="@drawable/distance"
                    android:textColor="@color/dark_gray"
                    android:textSize="@dimen/font_size_small"
                    tools:text="9.3 km"/>

            </LinearLayout>
            <TextView
                android:id="@+id/milestone_steps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_gray"
                android:textSize="@dimen/font_size_small"
                app:drawableStartCompat="@drawable/steps"
                tools:text="12,345"/>

            <TextView
                android:id="@+id/milestone_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/dark_gray"
                tools:text="Diese ist länger als sie in die Zeile passt, mal schauen, was passiert"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:id="@+id/milestone_locked"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/dark_gray"
        android:textSize="@dimen/font_size_small"
        android:textStyle="italic"
        android:layout_gravity="center"
        android:padding="@dimen/padding_medium"
        android:visibility="gone"
        app:drawableTopCompat="@drawable/lock"
        app:drawableTint="@color/dark_gray"
        tools:visibility="visible"
        tools:text="@string/unlock_by_walking_distance" />
</LinearLayout>