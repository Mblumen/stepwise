<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@color/white">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <ImageView
            android:id="@+id/milestone_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/milestone_image_content_description"
            tools:src="@drawable/berlin"/>

        <ImageView
            android:id="@+id/milestone_status_badge"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:layout_gravity="top|end"
            android:layout_margin="2dp"
            android:src="@drawable/check_circle"
            android:contentDescription="@string/milestone_completed"
            app:tint="@color/success_green"
            android:visibility="gone"
            tools:visibility="visible"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/milestone_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_small"
            android:textColor="@color/dark_gray"
            tools:text="Title Spot"/>

        <TextView
            android:id="@+id/milestone_steps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_gray"
            android:textSize="@dimen/font_size_small"
            app:drawableStartCompat="@drawable/steps"
            tools:text="12,345"/>

        <TextView
            android:id="@+id/milestone_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/dark_gray"
            tools:text="Description Spot and some more text"/>
    </LinearLayout>
</LinearLayout>