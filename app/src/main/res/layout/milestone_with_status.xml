<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/container_margin"
    android:layout_marginBottom="@dimen/list_item_spacing"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true"
    app:strokeColor="@color/dark_gray"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/dark_gray">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/light_gray"
        android:layout_marginBottom="@dimen/list_item_spacing">

        <LinearLayout
            android:id="@+id/milestone_unlocked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:padding="8dp">
            <FrameLayout
                android:layout_width="@dimen/image_size"
                android:layout_height="@dimen/image_size"
                android:layout_gravity="center">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/milestone_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/milestone_image_content_description"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Circle"
                    tools:src="@drawable/berlin"/>

                <ImageView
                    android:id="@+id/milestone_status_badge"
                    android:layout_width="@dimen/icon_size_big"
                    android:layout_height="@dimen/icon_size_big"
                    android:layout_gravity="top|center"
                    android:layout_margin="2dp"
                    android:src="@drawable/check_circle"
                    android:contentDescription="@string/milestone_completed"
                    app:tint="@color/success_green"
                    android:visibility="gone"
                    tools:visibility="visible"/>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/milestone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="@dimen/card_description_padding"
                android:paddingEnd="@dimen/card_description_padding"
                android:layout_gravity="center"
                tools:layout_width="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/milestone_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:textSize="@dimen/font_size_normal"
                        android:textColor="@color/dark_gray"
                        android:layout_marginBottom="2dp"
                        tools:text="Title Spot" />

                    <ImageButton
                        android:id="@+id/milestone_map_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/show_on_map"
                        android:src="@drawable/map"
                        app:tint="@color/dark_gray" />
                </LinearLayout>

                <TextView
                    android:id="@+id/milestone_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:drawableStartCompat="@drawable/distance"
                    android:textColor="@color/dark_gray"
                    android:textSize="@dimen/font_size_small"
                    tools:text="9.3 km"/>

                <TextView
                    android:id="@+id/milestone_steps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/dark_gray"
                    android:textSize="@dimen/font_size_small"
                    app:drawableStartCompat="@drawable/steps"
                    tools:text="12,345"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/locked_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/padding_medium"
            tools:visibility="gone">

            <!-- Lock TextView centered -->
            <TextView
                android:id="@+id/milestone_locked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/dark_gray"
                android:textSize="@dimen/font_size_small"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_gravity="center"
                app:drawableTopCompat="@drawable/lock"
                app:drawableTint="@color/dark_gray"
                tools:text="@string/unlock_by_walking_distance" />
            <ProgressBar
                android:id="@+id/milestone_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="@dimen/progress_bar_height"
                android:max="100"
                android:visibility="gone"
                android:progressTint="@color/dark_gray"
                tools:progress="50"/>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>