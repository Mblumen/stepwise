    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/refresh_time_fitbit"
            android:text="@string/refresh_time_in_minutes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:labelFor="@+id/refresh_time_fitbit_input"
            android:enabled="false"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/container_margin">

            <EditText
                android:id="@+id/refresh_time_fitbit_input"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:autofillHints="stepLength"
                android:enabled="false"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="@dimen/fragment_horizontal_margin">
        <TextView
            android:text="@string/selected_step_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:labelFor="@+id/stepSource"/>
        <Spinner
            android:id="@+id/sensorSpinner"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/container_margin"
            android:prompt="@string/selected_step_counter"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/fragment_horizontal_margin"
        android:background="?attr/colorPrimary">
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="?attr/colorOnPrimary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/update_tracks_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/fragment_horizontal_margin">

        <ImageView
            android:id="@+id/update_tracks_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/update_tracks"
            android:src="@drawable/map"
            app:tint="?attr/colorOnPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:text="@string/update_tracks"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <TextView
                    android:id="@+id/update_tracks_available"
                    android:text="@string/update_available"
                    android:textSize="14sp"
                    android:textColor="@color/success_green"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/button_margin"
                    android:visibility="gone"
                    tools:visibility="visible"/>
            </LinearLayout>

            <TextView
                android:id="@+id/update_tracks_desc"
                android:text="@string/update_tracks_desc"
                android:textSize="13sp"
                android:textColor="?attr/colorOnPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/update_tracks_button"
            android:minHeight="0dp"
            android:layout_width="50dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:icon="@drawable/sync"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:layout_height="wrap_content"
            />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/update_achievements_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/fragment_horizontal_margin">

        <ImageView
            android:id="@+id/update_achievements_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/update_achievements"
            android:src="@drawable/trophy"
            app:tint="?attr/colorOnPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:text="@string/update_achievements"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <TextView
                    android:id="@+id/update_achievements_available"
                    android:text="@string/update_available"
                    android:textSize="14sp"
                    android:textColor="@color/success_green"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/button_margin"
                    android:visibility="gone"/>
            </LinearLayout>


            <TextView
                android:id="@+id/update_achievements_desc"
                android:text="@string/update_achievements_desc"
                android:textSize="13sp"
                android:textColor="?attr/colorOnPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/update_achievements_button"
            android:minHeight="0dp"
            android:layout_width="50dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:icon="@drawable/sync"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:layout_height="wrap_content"
            />
    </LinearLayout>
</LinearLayout >