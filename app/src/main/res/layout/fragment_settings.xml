<?xml version="1.0" encoding="utf-8"?>
<LinearLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="de.hd.stepwise.ui.settings.UserSettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:text="@string/step_length_in_meters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:labelFor="@+id/step_length_input"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/container_margin">

            <EditText
                android:id="@+id/step_length_input"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:autofillHints="stepLength" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/dark_mode_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dark_mode"
        android:checked="true"
        android:layout_marginTop="@dimen/container_margin" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/show_completed_tracks_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/show_completed_tracks"
        android:checked="true"
        android:layout_marginTop="@dimen/container_margin" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/show_locked_milestones_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/show_locked_milestones"
        android:checked="false"
        android:layout_marginTop="@dimen/container_margin" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/fragment_horizontal_margin"
        android:background="?attr/colorPrimary">
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="?attr/colorOnPrimary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/fitbit_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/fragment_horizontal_margin">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_fitbit"
            android:contentDescription="@string/fitbit"
            />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/fitbit_status_title"
                android:text="@string/fitbit"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="?attr/colorOnPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/fitbit_status_desc"
                android:text="@string/not_connected"
                android:textSize="13sp"
                android:textColor="?attr/colorOnPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fitbit_action_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connect"/>
    </LinearLayout>
