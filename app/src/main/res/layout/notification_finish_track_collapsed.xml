<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- Track Image -->
    <ImageView
        android:id="@+id/track_image"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:layout_marginEnd="8dp"
        tools:src="@drawable/map"
        tools:tint="@color/notification_text_color"
        android:contentDescription="@string/track_image"
        android:scaleType="centerCrop" />

    <!-- Text Content -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <TextView
            android:id="@+id/notification_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/track_completed"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/notification_text_color" />

        <TextView
            android:id="@+id/track_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Start: Berlin"
            android:textColor="@color/notification_text_color"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
