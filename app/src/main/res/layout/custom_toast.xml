<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/custom_toast_container"
    android:orientation="horizontal"
    android:background="@drawable/bg_toast"
    android:padding="@dimen/toast_padding"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/toast_icon"
        android:layout_width="@dimen/icon_size"
        android:layout_height="@dimen/icon_size"
        android:layout_marginEnd="@dimen/image_margin"
        android:contentDescription="@string/toast_icon_desc"
        tools:src="@drawable/check_circle"
        tools:tint="@color/error_red"/>

    <TextView
        android:id="@+id/toast_text"
        android:textColor="@color/light_gray"
        android:textSize="@dimen/font_size_normal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Custom Toast"/>
</LinearLayout>