<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:layout_gravity="start"
    android:padding="4dp">

    <ImageView
        android:id="@+id/milestone_image"
        android:layout_width="@dimen/icon_size_very_large"
        android:layout_height="@dimen/icon_size_very_large"
        android:contentDescription="@string/milestone_image_content_description"
        android:scaleType="centerCrop"
        android:src="@drawable/berlin"
        android:layout_marginBottom="@dimen/image_margin" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/padding_small"
        android:layout_marginStart="@dimen/image_margin"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/notification_text_color"
            android:textSize="@dimen/font_size_header"
            tools:text="Berlin"/>

        <TextView
            android:id="@+id/success_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/notification_text_color"
            android:textSize="@dimen/font_size_small"
            android:text="@string/milestone_reached"/>
    </LinearLayout>

</LinearLayout>