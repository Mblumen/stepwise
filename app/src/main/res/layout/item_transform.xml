<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_weight="1"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/active_track_item_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFEEEEEE"
        android:layout_marginBottom="@dimen/list_item_spacing"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/active_track_item_base_image"
            android:layout_width="@dimen/image_size"
            android:layout_height="@dimen/image_size"
            android:contentDescription="@string/image_view_item_transform_content_description"
            android:layout_margin="5dp"
            tools:src="@drawable/barcelona" />

        <TextView
            android:id="@+id/active_track_item_base_title"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="@dimen/font_size_small"
            android:textColor="@color/dark_gray"
            tools:text="This is item # xx" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/active_track_item_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="@dimen/card_radius"
        app:cardElevation="@dimen/card_elevation">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#EEEEEE"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Image with overlayed title -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <ImageView
                    android:id="@+id/active_track_item_details_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/active_track_item_details_image_content_description"
                    tools:src="@drawable/barcelona" />

                <TextView
                    android:id="@+id/active_track_item_details_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#AA000000"
                    android:padding="12dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/font_size_header"
                    android:textStyle="bold"
                    tools:text="Track Name"/>
            </FrameLayout>

            <!-- Description below the image -->
            <LinearLayout
                android:id="@+id/active_track_item_details_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_description_padding">

                <!-- Start Point -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/text_spacing">

                    <ImageView
                        android:layout_width="@dimen/icon_size"
                        android:layout_height="@dimen/icon_size"
                        android:src="@drawable/home"
                        android:contentDescription="@string/track_start_point_icon_description"
                        app:tint="@color/dark_gray" />

                    <TextView
                        android:id="@+id/active_track_item_details_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/icon_text_margin_start"
                        android:textColor="@color/dark_gray"
                        android:textSize="@dimen/font_size_small"
                        tools:text="Barcelona"/>
                </LinearLayout>

                <!-- End Point -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="@dimen/text_spacing">

                    <ImageView
                        android:layout_width="@dimen/icon_size"
                        android:layout_height="@dimen/icon_size"
                        android:src="@drawable/flag"
                        android:contentDescription="@string/track_end_point_icon_description"
                        app:tint="@color/dark_gray" />

                    <TextView
                        android:id="@+id/active_track_item_details_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/icon_text_margin_start"
                        android:textColor="@color/dark_gray"
                        android:textSize="@dimen/font_size_small"
                        tools:text="Paris"/>
                </LinearLayout>

                <!-- Total Steps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size"
                        android:layout_height="@dimen/icon_size"
                        android:src="@drawable/steps"
                        android:contentDescription="@string/track_distance_icon_description"
                        app:tint="@color/dark_gray" />

                    <TextView
                        android:id="@+id/active_track_item_details_steps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/icon_text_margin_start"
                        android:textColor="@color/dark_gray"
                        android:textSize="@dimen/font_size_small"
                        tools:text="12,345"/>
                </LinearLayout>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/active_track_item_details_milestones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>