<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.milestones.MilestoneFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingBottom="72dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/light_gray">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header with background image and title -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/image_size_large">

                <ImageView
                    android:id="@+id/image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/active_track_item_details_image_content_description"
                    tools:src="@drawable/barcelona" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/transparent_black">
                    <TextView
                        android:id="@+id/title"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="@dimen/card_description_padding"
                        android:textColor="@color/white"
                        android:textSize="@dimen/font_size_header"
                        android:textStyle="bold"
                        tools:text="Milestone Name" />
                    <TextView
                        android:id="@+id/step_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:textColor="@color/white"
                        android:textSize="@dimen/font_size_small"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/steps"
                        app:drawableTint="@color/white"
                        android:layout_gravity="center"
                        tools:text="5" />
                </LinearLayout>

            </FrameLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textColor="@color/black"
                android:textSize="@dimen/font_size_small"
                tools:text="This is a milestone description providing more detailed information." />

            <!-- Additional detail images -->
            <ImageView
                android:id="@+id/detail_image_1"
                android:layout_width="match_parent"
                android:layout_height="@dimen/image_size_large"
                android:layout_margin="@dimen/image_margin_large"
                android:scaleType="centerCrop"
                android:contentDescription="@string/detail_image_description"
                tools:src="@drawable/barcelona" />

            <ImageView
                android:id="@+id/detail_image_2"
                android:layout_width="match_parent"
                android:layout_height="@dimen/image_size_large"
                android:layout_margin="@dimen/image_margin_large"
                android:scaleType="centerCrop"
                android:contentDescription="@string/detail_image_description"
                tools:src="@drawable/barcelona" />
        </LinearLayout>
    </ScrollView>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_view_on_map"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="@dimen/card_description_padding"
        android:text="@string/show_on_map"
        android:textStyle="bold"
        app:icon="@drawable/map"
        app:iconGravity="textStart"
        app:iconTint="@color/white"
        android:backgroundTint="@color/dark_gray"
        android:textColor="@color/white" />
</androidx.constraintlayout.widget.ConstraintLayout>
