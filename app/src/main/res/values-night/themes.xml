<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FitbitTracks" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/dark_gray</item>
        <item name="colorPrimaryVariant">@color/light_gray</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/light_gray</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="bottomNavigationStyle">@style/Widget.FitbitTracks.BottomNavigationView</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Widget.FitbitTracks.BottomNavigationView" parent="ThemeOverlay.Material3.Toolbar.Surface">
        <item name="backgroundTint">@color/dark_gray</item>
        <item name="itemIconTint">@drawable/bottom_nav_item_selector_night</item>
        <item name="itemTextColor">@drawable/bottom_nav_item_selector_night</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

</resources>